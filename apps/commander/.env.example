# COMMANDER — WhatsApp field sensor for CORE COMMAND
# Copy to .env (PowerShell: Copy-Item .env.example .env) then fill secrets.

# --- HTTP ---------------------------------------------------------------
# Railway injects PORT automatically; COMMANDER_PORT is the local fallback.
COMMANDER_PORT=8787
NODE_ENV=development

# --- Meta WhatsApp Cloud API (REQUIRED) ---------------------------------
# Verify token: any string you choose; must match the value entered in the
# Meta App dashboard webhook config (used on the GET handshake).
META_VERIFY_TOKEN=change-me-verify-token
# App secret: Meta App → Settings → Basic → App secret. Used to verify the
# X-Hub-Signature-256 HMAC on every inbound POST.
META_APP_SECRET=change-me-app-secret

# --- CORE Memory (Supabase) ---------------------------------------------
# Optional: if BOTH are set, COMMANDER writes to public.incoming_messages via
# the service_role (bypasses RLS). If absent/failing, it falls back to the
# append-only JSONL audit file below (always written as a safety net).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Sinks & misc -------------------------------------------------------
COMMANDER_INCOMING_TABLE=incoming_messages
COMMANDER_AUDIT_FILE=commander-audit.jsonl
COMMANDER_LOG_LEVEL=info
